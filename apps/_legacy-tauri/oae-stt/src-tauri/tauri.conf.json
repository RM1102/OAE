{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OAE STT",
  "version": "0.1.0",
  "identifier": "computer.oae.stt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OAE STT",
        "width": 900,
        "height": 640,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "./entitlements.plist",
      "hardenedRuntime": true,
      "infoPlist": "./Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
